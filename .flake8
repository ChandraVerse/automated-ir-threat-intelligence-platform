[flake8]
max-line-length = 120
extend-ignore = E501, W503
per-file-ignores =
    tests/*: E302, E303
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    wazuh-integration,
    ioc-pipeline,
    soar-automation,
    report-generator,
    memory-analysis,
    docs,
    grafana,
    config,
    samples
